<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blblPageBackdrop">

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginStart="@dimen/tv_safe_margin_horizontal"
        android:layout_marginTop="@dimen/tv_safe_margin_vertical"
        android:background="?attr/blblFocusBgRound"
        android:contentDescription="@string/search_backspace"
        android:focusable="true"
        android:padding="@dimen/sidebar_settings_padding"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_back"
        app:tint="?attr/blblOnPageBackdropSecondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="@dimen/tv_safe_margin_horizontal"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="我的关注"
        android:textColor="?attr/blblOnPageBackdrop"
        android:textAppearance="@style/TextAppearance.Blbl.PageTitle"
        app:layout_constraintBottom_toBottomOf="@id/btn_back"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btn_back"
        app:layout_constraintTop_toTopOf="@id/btn_back" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_back">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:descendantFocusability="afterDescendants"
            android:focusable="true"
            android:paddingStart="@dimen/tv_safe_margin_horizontal"
            android:paddingTop="16dp"
            android:paddingEnd="@dimen/tv_safe_margin_horizontal"
            android:paddingBottom="@dimen/tv_safe_margin_vertical" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <LinearLayout
        android:id="@+id/login_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/swipe_refresh"
        app:layout_constraintEnd_toEndOf="@id/swipe_refresh"
        app:layout_constraintStart_toStartOf="@id/swipe_refresh"
        app:layout_constraintTop_toTopOf="@id/swipe_refresh">

        <TextView
            android:id="@+id/tv_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关注列表需要登录"
            android:textColor="?attr/blblOnPageBackdrop"
            android:textAppearance="@style/TextAppearance.Blbl.PageTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="wrap_content"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:minWidth="220dp"
            android:stateListAnimator="@animator/blbl_focus_scale_button"
            android:text="二维码登录"
            android:textSize="20sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
