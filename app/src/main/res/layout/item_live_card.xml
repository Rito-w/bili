<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Blbl.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/video_card_margin"
    android:clickable="true"
    android:focusable="true"
    android:importantForAccessibility="yes"
    app:cardUseCompatPadding="false"
    app:strokeColor="?attr/blblFocusStrokeFocusOnlyColor">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAccessibility="noHideDescendants">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_cover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_cover"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:contentDescription="@null"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/guideline_cover_fade_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintGuide_percent="0.5" />

            <View
                android:id="@+id/v_cover_fade"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:background="@drawable/blbl_scrim_bottom"
                android:importantForAccessibility="no"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/guideline_cover_fade_top" />

            <TextView
                android:id="@+id/tv_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:background="@drawable/bg_live_badge"
                android:paddingHorizontal="@dimen/live_badge_padding_horizontal"
                android:paddingVertical="@dimen/live_badge_padding_vertical"
                android:text="@string/badge_live"
                android:textColor="@android:color/white"
                android:textSize="@dimen/video_card_duration_text_size"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <LinearLayout
                android:id="@+id/ll_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/video_card_text_margin"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/video_card_duration_padding_h"
                android:paddingVertical="@dimen/video_card_duration_padding_v"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/iv_stat_online"
                    android:layout_width="@dimen/video_card_stat_icon_size"
                    android:layout_height="@dimen/video_card_stat_icon_size"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_stat_play"
                    app:tint="@color/blbl_text_on_media" />

                <TextView
                    android:id="@+id/tv_online"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:shadowColor="@color/blbl_scrim_strong"
                    android:shadowDy="1"
                    android:shadowRadius="2"
                    android:textColor="@color/blbl_text_on_media"
                    android:textSize="@dimen/video_card_stat_text_size"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="@dimen/video_card_title_block_height"
            android:layout_marginHorizontal="@dimen/video_card_text_margin"
            android:layout_marginTop="@dimen/video_card_text_margin"
            android:ellipsize="end"
            android:gravity="top"
            android:includeFontPadding="false"
            android:lineSpacingExtra="@dimen/video_card_title_line_spacing"
            android:lines="2"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Blbl.CardTitle"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_cover" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="@dimen/video_card_meta_block_height"
            android:layout_marginHorizontal="@dimen/video_card_text_margin"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Blbl.Supporting"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
