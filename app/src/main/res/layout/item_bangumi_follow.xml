<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Blbl.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/video_card_margin"
    android:clickable="true"
    android:focusable="true"
    android:importantForAccessibility="yes"
    app:cardBackgroundColor="@color/blbl_scrim_transparent"
    app:cardUseCompatPadding="false"
    app:strokeColor="?attr/blblFocusStrokeFocusOnlyColor">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:importantForAccessibility="noHideDescendants">

        <ImageView
            android:id="@+id/iv_cover"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_access_badge_text"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/pgc_card_badge_height"
            android:layout_margin="@dimen/pgc_card_text_padding_horizontal"
            android:background="@drawable/bg_pgc_access_badge"
            android:gravity="center"
            android:minWidth="@dimen/pgc_card_badge_min_width"
            android:paddingHorizontal="@dimen/pgc_card_badge_padding_horizontal"
            android:textColor="@android:color/white"
            android:textSize="@dimen/tv_text_size_supporting"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="@id/iv_cover"
            app:layout_constraintTop_toTopOf="@id/iv_cover" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="@dimen/pgc_card_title_block_height"
            android:layout_marginHorizontal="@dimen/pgc_card_text_padding_horizontal"
            android:layout_marginTop="@dimen/pgc_card_text_padding_top"
            android:ellipsize="end"
            android:gravity="top"
            android:includeFontPadding="false"
            android:lineSpacingExtra="@dimen/video_card_title_line_spacing"
            android:lines="2"
            android:maxLines="2"
            android:textColor="?attr/colorOnSurface"
            android:textSize="@dimen/pgc_card_title_text_size"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_cover" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="0dp"
            android:layout_height="@dimen/pgc_card_meta_block_height"
            android:layout_marginHorizontal="@dimen/pgc_card_text_padding_horizontal"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Blbl.Supporting"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
