<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/blblPageBackdrop">

    <ImageView
        android:id="@+id/iv_search"
        android:layout_width="@dimen/search_header_icon_size"
        android:layout_height="@dimen/search_header_icon_size"
        android:layout_marginStart="@dimen/tv_safe_margin_horizontal"
        android:layout_marginTop="@dimen/tv_safe_margin_vertical"
        android:contentDescription="@string/tab_search"
        android:src="@drawable/ic_nav_search"
        app:tint="?attr/blblOnPageBackdropSecondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/tv_query"
        android:layout_width="0dp"
        android:layout_height="@dimen/search_query_height"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="@dimen/tv_safe_margin_horizontal"
        android:background="@drawable/bg_search_query"
        android:ellipsize="end"
        android:gravity="center_vertical"
        android:includeFontPadding="false"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:textColor="?attr/blblOnPageBackdrop"
        android:textColorHint="?attr/blblOnPageBackdropSecondary"
        android:textSize="@dimen/search_query_text_size"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/iv_search"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_search"
        app:layout_constraintTop_toTopOf="@id/iv_search" />

    <LinearLayout
        android:id="@+id/panel_input"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_query">

        <LinearLayout
            android:id="@+id/panel_keyboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/tv_safe_margin_horizontal"
            android:layout_marginEnd="16dp"
            android:layout_weight="1.25"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="@dimen/focus_safe_padding_h"
            android:paddingTop="@dimen/focus_safe_padding_v"
            android:paddingEnd="@dimen/focus_safe_padding_h"
            android:paddingBottom="@dimen/focus_safe_padding_v">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/search_input_section"
                android:textColor="?attr/blblOnPageBackdrop"
                android:textSize="@dimen/tv_text_size_supporting"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_clear"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/search_action_height"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/blbl_focus_scale"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="@dimen/tv_card_corner_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/blblFocusStrokeColor"
                    app:strokeWidth="@dimen/tv_focus_outline_width">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/search_clear"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/search_action_text_size" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_backspace"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/search_action_height"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/blbl_focus_scale"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="@dimen/tv_card_corner_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/blblFocusStrokeColor"
                    app:strokeWidth="@dimen/tv_focus_outline_width">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/search_backspace"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/search_action_text_size" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_keys"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipChildren="false"
                android:clipToPadding="false" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btn_search"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/search_action_height"
                    android:clickable="true"
                    android:focusable="true"
                    android:stateListAnimator="@animator/blbl_focus_scale"
                    app:cardBackgroundColor="?attr/blblAccent"
                    app:cardCornerRadius="@dimen/tv_card_corner_radius"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/blblFocusStrokeColor"
                    app:strokeWidth="@dimen/tv_focus_outline_width">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="@string/search_action"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        android:textSize="@dimen/search_action_text_size" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/panel_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="16dp"
            android:layout_weight="0.8"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="@dimen/focus_safe_padding_h"
            android:paddingEnd="@dimen/focus_safe_padding_h"
            android:paddingBottom="@dimen/focus_safe_padding_v">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/search_history_section"
                android:textColor="?attr/blblOnPageBackdrop"
                android:textSize="@dimen/tv_text_size_supporting"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_suggest"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingTop="4dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_clear_history"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:clickable="true"
                android:focusable="true"
                android:stateListAnimator="@animator/blbl_focus_scale"
                android:visibility="gone"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="@dimen/tv_card_corner_radius"
                app:cardElevation="0dp"
                app:strokeColor="?attr/blblFocusStrokeColor"
                app:strokeWidth="@dimen/tv_focus_outline_width">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/search_clear_history"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="18sp" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="@dimen/tv_safe_margin_horizontal"
            android:layout_weight="1"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="@dimen/focus_safe_padding_h"
            android:paddingTop="4dp"
            android:paddingEnd="@dimen/focus_safe_padding_h"
            android:paddingBottom="@dimen/focus_safe_padding_v">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/search_hot_section"
                android:textColor="?attr/blblOnPageBackdrop"
                android:textSize="@dimen/tv_text_size_supporting"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_hot"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipChildren="false"
                android:clipToPadding="false" />
        </LinearLayout>
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_results"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_query">

        <blbl.cat3399.core.ui.UserScaleTabLayout
            android:id="@+id/tab_layout"
            style="@style/Widget.Blbl.TabLayout"
            android:layout_width="0dp"
            android:layout_height="@dimen/tv_top_level_header_height"
            android:layout_marginStart="@dimen/tv_safe_margin_horizontal"
            android:layout_marginEnd="16dp"
            android:background="@android:color/transparent"
            android:focusable="false"
            app:layout_constraintEnd_toStartOf="@id/btn_sort"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tabGravity="start"
            app:tabMode="scrollable" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_sort"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginEnd="@dimen/tv_safe_margin_horizontal"
            android:clickable="true"
            android:focusable="true"
            android:stateListAnimator="@animator/blbl_focus_scale"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="@dimen/tv_card_corner_radius"
            app:cardElevation="0dp"
            app:strokeColor="?attr/blblFocusStrokeColor"
            app:strokeWidth="@dimen/tv_focus_outline_width"
            app:layout_constraintBaseline_toBaselineOf="@id/tab_layout"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@string/search_sort_totalrank"
                    android:src="@drawable/ic_sort"
                    app:tint="?android:attr/textColorSecondary" />

                <TextView
                    android:id="@+id/tv_sort"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_sort_totalrank"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="18sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/tv_safe_margin_horizontal"
            android:layout_marginEnd="@dimen/tv_safe_margin_horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_layout">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_results"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:descendantFocusability="afterDescendants"
                android:focusable="true"
                android:paddingTop="16dp"
                android:paddingBottom="@dimen/tv_safe_margin_vertical" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <TextView
            android:id="@+id/tv_results_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:text="@string/search_unsupported"
            android:textColor="?attr/blblOnPageBackdropSecondary"
            android:textSize="@dimen/tv_text_size_supporting"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_layout" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
