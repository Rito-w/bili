<?xml version="1.0" encoding="utf-8"?>
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="@dimen/tv_focus_list_inset_horizontal"
    android:insetTop="@dimen/tv_focus_list_inset_vertical"
    android:insetRight="@dimen/tv_focus_list_inset_horizontal"
    android:insetBottom="@dimen/tv_focus_list_inset_vertical">

    <selector>
        <item android:state_pressed="true">
            <shape android:shape="rectangle">
                <solid android:color="@color/blbl_focus_fill_pressed" />
                <stroke
                    android:width="@dimen/tv_focus_outline_width"
                    android:color="@color/blbl_focus_white" />
                <corners android:radius="@dimen/tv_focus_corner_radius" />
            </shape>
        </item>
        <item android:state_focused="true">
            <shape android:shape="rectangle">
                <solid android:color="@color/blbl_focus_fill" />
                <stroke
                    android:width="@dimen/tv_focus_outline_width"
                    android:color="@color/blbl_focus_white" />
                <corners android:radius="@dimen/tv_focus_corner_radius" />
            </shape>
        </item>
        <item android:state_selected="true">
            <shape android:shape="rectangle">
                <solid android:color="@color/blbl_focus_fill" />
                <stroke
                    android:width="@dimen/tv_focus_outline_width"
                    android:color="@color/blbl_focus_white" />
                <corners android:radius="@dimen/tv_focus_corner_radius" />
            </shape>
        </item>
        <item android:state_activated="true">
            <shape android:shape="rectangle">
                <solid android:color="@color/blbl_focus_fill" />
                <stroke
                    android:width="@dimen/tv_focus_outline_width"
                    android:color="@color/blbl_focus_white" />
                <corners android:radius="@dimen/tv_focus_corner_radius" />
            </shape>
        </item>
        <item>
            <shape android:shape="rectangle">
                <solid android:color="@color/blbl_scrim_transparent" />
                <corners android:radius="@dimen/tv_focus_corner_radius" />
            </shape>
        </item>
    </selector>
</inset>
