<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="@color/blbl_brand_accent" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#3311141B" />
            <stroke
                android:width="1dp"
                android:color="@color/blbl_brand_accent_weak" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
