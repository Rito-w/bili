<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/blbl_focus_shadow" />
            <corners android:radius="@dimen/tv_focus_shadow_corner_radius" />
        </shape>
    </item>
    <item
        android:left="@dimen/tv_focus_shadow_inset"
        android:top="@dimen/tv_focus_shadow_inset"
        android:right="@dimen/tv_focus_shadow_inset"
        android:bottom="@dimen/tv_focus_shadow_inset">
        <shape android:shape="rectangle">
            <solid android:color="?attr/blblDialogSurface" />
            <stroke
                android:width="@dimen/tv_focus_outline_width"
                android:color="@color/blbl_focus_white" />
            <corners android:radius="@dimen/tv_focus_corner_radius" />
        </shape>
    </item>
</layer-list>
