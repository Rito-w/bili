<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <solid android:color="?attr/colorSurface" />
            <stroke
                android:width="@dimen/tv_focus_outline_width"
                android:color="?attr/blblFocusStrokeColor" />
            <corners android:radius="@dimen/tv_card_corner_radius" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="?attr/colorSurface" />
            <stroke
                android:width="1dp"
                android:color="@color/blbl_settings_divider" />
            <corners android:radius="@dimen/tv_card_corner_radius" />
        </shape>
    </item>
</selector>
