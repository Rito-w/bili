<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/blbl_focus_fill" />
            <stroke
                android:width="@dimen/tv_focus_outline_width"
                android:color="?attr/blblAccent" />
            <corners android:radius="@dimen/tv_focus_corner_radius" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/blbl_focus_fill_pressed" />
            <stroke
                android:width="@dimen/tv_focus_outline_width"
                android:color="?attr/blblAccent" />
            <corners android:radius="@dimen/tv_focus_corner_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/blbl_scrim_transparent" />
            <corners android:radius="@dimen/tv_focus_corner_radius" />
        </shape>
    </item>
</selector>
