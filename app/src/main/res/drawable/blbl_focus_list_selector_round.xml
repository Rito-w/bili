<?xml version="1.0" encoding="utf-8"?>
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="@dimen/tv_focus_list_inset_horizontal"
    android:insetTop="@dimen/tv_focus_list_inset_vertical"
    android:insetRight="@dimen/tv_focus_list_inset_horizontal"
    android:insetBottom="@dimen/tv_focus_list_inset_vertical">

    <selector>
        <item
            android:drawable="@drawable/blbl_focus_surface_accent"
            android:state_pressed="true" />
        <item
            android:drawable="@drawable/blbl_focus_surface_accent"
            android:state_focused="true" />
        <item
            android:drawable="@drawable/blbl_focus_surface_accent"
            android:state_selected="true" />
        <item
            android:drawable="@drawable/blbl_focus_surface_accent"
            android:state_activated="true" />
        <item>
            <shape android:shape="rectangle">
                <solid android:color="@color/blbl_scrim_transparent" />
                <corners android:radius="@dimen/tv_focus_corner_radius" />
            </shape>
        </item>
    </selector>
</inset>
