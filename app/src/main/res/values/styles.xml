<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShapeAppearanceOverlay_Blbl_Circular">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlay_Blbl_Rounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/tv_card_corner_radius</item>
    </style>

    <style name="ShapeAppearanceOverlay_Blbl_Card">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/tv_card_corner_radius</item>
    </style>

    <style name="ShapeAppearanceOverlay_Blbl_Panel">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">@dimen/tv_panel_corner_radius</item>
    </style>

    <style name="ThemeOverlay.Blbl.Accent.Brand" parent="ThemeOverlay.MaterialComponents">
        <item name="blblAccent">@color/blbl_brand_accent</item>
        <item name="blblAccentContainer">@color/blbl_brand_accent_container</item>
        <item name="blblAccentWeak">@color/blbl_brand_accent_weak</item>
        <item name="blblAccentPressed">@color/blbl_brand_accent_pressed</item>
    </style>

    <!-- Compatibility name consumed by ThemePresets; values come from the single brand accent. -->
    <style name="ThemeOverlay.Blbl.Accent.Violet" parent="ThemeOverlay.Blbl.Accent.Brand" />

    <style name="ThemeOverlay.Blbl.Accent.TvPink" parent="ThemeOverlay.MaterialComponents">
        <item name="blblAccent">@color/blbl_accent_tv_pink</item>
        <item name="blblAccentContainer">@color/blbl_accent_tv_pink_container</item>
        <item name="blblAccentWeak">@color/blbl_accent_tv_pink_weak</item>
        <item name="blblAccentPressed">@color/blbl_accent_tv_pink_pressed</item>
    </style>

    <style name="ThemeOverlay.Blbl.Accent.Classic" parent="ThemeOverlay.MaterialComponents">
        <item name="blblAccent">@color/blbl_accent_classic</item>
        <item name="blblAccentContainer">@color/blbl_accent_classic_container</item>
        <item name="blblAccentWeak">@color/blbl_accent_classic_weak</item>
        <item name="blblAccentPressed">@color/blbl_accent_classic_pressed</item>
    </style>

    <style name="ThemeOverlay.Blbl.TransparentDialog" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="ThemeOverlay.Blbl.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">?attr/blblAccent</item>
        <item name="colorSurface">?attr/blblDialogSurface</item>
        <item name="colorOnPrimary">?attr/colorOnSurface</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Widget.Blbl.MaterialAlertDialog.Title.Text</item>
        <item name="materialAlertDialogBodyTextStyle">@style/Widget.Blbl.MaterialAlertDialog.Body.Text</item>
        <!-- For single-choice dialogs (ListView in AlertDialog): inject via listViewStyle for reliability. -->
        <item name="android:listViewStyle">@style/Widget.Blbl.Dialog.ListView</item>
        <item name="android:dropDownListViewStyle">@style/Widget.Blbl.Dialog.ListView</item>
    </style>

    <style name="ThemeOverlay.Blbl.Player.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/blbl_brand_accent</item>
        <item name="colorOnPrimary">@color/blbl_text</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Widget.Blbl.MaterialAlertDialog.Title.Text</item>
        <item name="materialAlertDialogBodyTextStyle">@style/Widget.Blbl.MaterialAlertDialog.Body.Text</item>
        <!-- Keep the list selector/focus behavior consistent with the player controls. -->
        <item name="android:listViewStyle">@style/Widget.Blbl.Dialog.ListView</item>
        <item name="android:dropDownListViewStyle">@style/Widget.Blbl.Dialog.ListView</item>
    </style>

    <style name="Widget.Blbl.Dialog.ListView" parent="Widget.AppCompat.ListView">
        <item name="android:listSelector">?attr/blblFocusListSelectorRound</item>
        <item name="android:divider">@android:color/transparent</item>
        <item name="android:dividerHeight">0dp</item>
        <item name="android:cacheColorHint">@android:color/transparent</item>
    </style>

    <style name="Widget.Blbl.MaterialAlertDialog.Title.Text" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">@dimen/tv_text_size_top_tab</item>
    </style>

    <style name="Widget.Blbl.MaterialAlertDialog.Body.Text" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">@dimen/tv_text_size_supporting</item>
    </style>

    <style name="TextAppearance.Blbl.PageTitle" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:textColor">?attr/blblOnPageBackdrop</item>
        <item name="android:textSize">@dimen/tv_text_size_page_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Blbl.TopTab" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">@dimen/tv_text_size_top_tab</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Blbl.CardTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">?attr/colorOnSurface</item>
        <item name="android:textSize">@dimen/tv_text_size_card_title</item>
    </style>

    <style name="TextAppearance.Blbl.Supporting" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">@dimen/tv_text_size_supporting</item>
    </style>

    <style name="TextAppearance.Blbl.Tab" parent="TextAppearance.Blbl.TopTab" />

    <style name="Widget.Blbl.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/blbl_card_surface</item>
        <item name="cardCornerRadius">@dimen/tv_card_corner_radius</item>
        <item name="cardElevation">@dimen/tv_card_elevation</item>
        <item name="strokeColor">?attr/blblFocusStrokeColor</item>
        <item name="strokeWidth">@dimen/tv_focus_outline_width</item>
        <item name="android:stateListAnimator">@animator/blbl_focus_scale</item>
    </style>

    <style name="Widget.Blbl.Panel" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">?attr/blblDialogSurface</item>
        <item name="cardCornerRadius">@dimen/tv_panel_corner_radius</item>
        <item name="cardElevation">@dimen/tv_panel_elevation</item>
    </style>

    <style name="Widget.Blbl.SmallAction" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:minWidth">@dimen/tv_small_action_min_size</item>
        <item name="android:minHeight">@dimen/tv_small_action_min_size</item>
        <item name="android:stateListAnimator">@animator/blbl_focus_scale_button</item>
        <item name="android:textAppearance">@style/TextAppearance.Blbl.Supporting</item>
    </style>

    <style name="Widget.Blbl.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabTextAppearance">@style/TextAppearance.Blbl.Tab</item>
        <item name="tabIndicator">@drawable/blbl_tab_indicator</item>
        <item name="tabIndicatorColor">?attr/blblAccent</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabBackground">?attr/blblFocusBgRound</item>
        <item name="tabSelectedTextColor">?attr/blblOnPageBackdrop</item>
        <item name="tabTextColor">?attr/blblOnPageBackdropSecondary</item>
        <item name="tabPaddingTop">4dp</item>
        <item name="tabPaddingBottom">2dp</item>
    </style>

    <!-- Player OSD sizing overlay: baseline values (scaled at runtime by userScale + autoScale). -->
    <style name="ThemeOverlay.Blbl.PlayerOsd.Normal" parent="ThemeOverlay.MaterialComponents">
        <item name="playerOsdButtonTargetSize">@dimen/player_osd_button_target_size</item>
        <item name="playerOsdPadTransport">@dimen/player_osd_pad_transport</item>
        <item name="playerOsdPadNormal">@dimen/player_osd_pad_normal</item>
        <item name="playerOsdPadSmall">@dimen/player_osd_pad_small</item>
        <item name="playerOsdGap">@dimen/player_osd_gap</item>
    </style>
</resources>
